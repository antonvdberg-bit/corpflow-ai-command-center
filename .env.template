# CorpFlow AI Command Center — Environment Template
#
# IMPORTANT:
# - This file is a template only. Do NOT commit real secrets.
# - Copy to `.env` locally (or set equivalent variables in your Codespace/CI).
#
# Optional single-blob config in Vercel: CORPFLOW_RUNTIME_CONFIG_JSON must be **strict JSON**
# (double quotes, no trailing commas, no comments). UTF-8 BOM is stripped at runtime.
# Invalid JSON fails closed: critical keys will read as missing until fixed.
#
# Keys resolved via cfg() (individual env var OR same key inside the JSON blob):
#   N8N_WEBHOOK_URL, N8N_CMP_WEBHOOK_URL, CMP_GITHUB_TOKEN, GH_WORKFLOW_TOKEN,
#   GITHUB_REPO, CMP_GITHUB_REPOSITORY, CMP_SANDBOX_BASE_REF
#
# ROOT access = general Factory infrastructure.
# TENANT access = per-client workspace IDs / routing identifiers.

# -----------------------------
# ROOT — LLM / AI
# -----------------------------
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-pro

# OpenAI-compatible backend (optional)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (used by `api/index.py`)
GROQ_API_KEY=

PROVISIONING_ENABLED=false

# -----------------------------
# ROOT — n8n / workflow webhooks
# -----------------------------
# Lead intake (`/api/main` POST → JSON forwarded here)
N8N_WEBHOOK_URL=https://YOUR_N8N_HOST/webhook/leads

# Optional: notify n8n when CMP sandbox GitHub dispatch runs (approve-build / sandbox-start)
N8N_CMP_WEBHOOK_URL=

# -----------------------------
# ROOT — GitHub (CMP sandbox branch automation)
# -----------------------------
# Repository as owner/name (used with repository_dispatch from Vercel)
GITHUB_REPO=

# Fine-grained or classic PAT with contents:write on this repo (store only in Vercel / secrets)
CMP_GITHUB_TOKEN=

# Optional alias for CMP_GITHUB_TOKEN (same cfg()/blob resolution)
GH_WORKFLOW_TOKEN=

# Optional: default base ref for sandbox branches
CMP_SANDBOX_BASE_REF=main

# -----------------------------
# ROOT — Telegram / Alerts
# -----------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------
# ROOT — Dormant Gate (production security)
# -----------------------------
# Enable to hide CMP bubble until an admin SESSION_TOKEN is verified.
DORMANT_GATE_ENABLED=true

# Master secret used to verify SESSION_TOKEN for admin unlocking.
# (In this template we use direct equality; in production prefer a hash.)
MASTER_ADMIN_KEY=

# Optional alias for MASTER_ADMIN_KEY (Vercel Secret). Client sends the same value as x-session-token.
ADMIN_PIN=

# -----------------------------
# ROOT — Web login (recommended)
# -----------------------------
# Admin login (factory-only). Once you login at /login, you get a secure HttpOnly cookie
# and never paste MASTER_ADMIN_KEY into pages again.
CORPFLOW_ADMIN_USERNAME=

# Easiest (plaintext) option: store in Vercel secrets. Optional: use *_HASH + *_SALT instead.
CORPFLOW_ADMIN_PASSWORD=
CORPFLOW_ADMIN_PASSWORD_SALT=
CORPFLOW_ADMIN_PASSWORD_HASH=

# Session cookie TTL (seconds). Default 43200 (12h). Min 600, max 86400.
CORPFLOW_SESSION_TTL_SEC=43200

# Auth backend selection (recommended: postgres)
# - postgres: use Postgres `auth_users` table (Elestio)
# - env: use CORPFLOW_ADMIN_USERNAME/CORPFLOW_ADMIN_PASSWORD
CORPFLOW_AUTH_BACKEND=postgres

# Tenants backend (recommended: postgres)
CORPFLOW_TENANTS_BACKEND=postgres

# CMP storage backend (recommended: postgres)
# - postgres: store tickets + console_json in Postgres (Elestio)
CORPFLOW_CMP_BACKEND=postgres

# -----------------------------
# ROOT — Postgres (Prisma / Vercel)
# -----------------------------
# Prisma reads this name from prisma/schema.prisma. Use the pooled Prisma Postgres URL for serverless.
# Prefer setting POSTGRES_URL as a direct Vercel env var (not only inside CORPFLOW_RUNTIME_CONFIG_JSON),
# so PrismaClient connects reliably at runtime.
POSTGRES_URL=
# Optional aliases (see lib/server/runtime-config.js)
# DATABASE_URL=
# PRISMA_DATABASE_URL=
#
# One-click schema (factory only): POST /api/factory/postgres/ensure-schema
# Auth: admin cookie session OR Bearer MASTER_ADMIN_KEY / x-session-token.
# Creates tenants, auth_users, cmp_tickets if missing (idempotent).

# Session token expected from admin; verify logic compares this to MASTER_ADMIN_KEY.
# Typically set by an admin bootstrap flow and stored client-side.
SESSION_TOKEN=

# WhatsApp number(s) for exec escalation (optional).
EXEC_WHATSAPP_NUMBER=

# -----------------------------
# ROOT — Vercel
# -----------------------------
# GitHub App / deployment signing PEM (required on Vercel for vanguard/notary.js APP signatures).
APP_PRIVATE_KEY=

VERCEL_AUTH_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# -----------------------------
# ROOT — Twilio / WhatsApp (optional)
# -----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ADMIN_WHATSAPP_NUMBER=
WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------
# ROOT — Sandbox / Code Execution (optional)
# -----------------------------
SANDBOX_TYPE=local
SANDBOX_TIMEOUT_SEC=30
SANDBOX_MAX_OUTPUT_KB=64

MSB_SERVER_URL=http://127.0.0.1:5555
MSB_API_KEY=
MSB_IMAGE=microsandbox/python
MSB_CPU_LIMIT=1.0
MSB_MEMORY_MB=512
MSB_START_TIMEOUT_SEC=30

# -----------------------------
# ROOT — External glue tooling (optional)
# -----------------------------
# Used by `sync_conductor.py` to poll a Google Apps Script endpoint.
GOOGLE_SCRIPT_URL=

# -----------------------------
# ROOT — Ethical Sentinel / Budget Gate
# -----------------------------
# Hard cap for cost_estimate/full_market_value_usd used by verify-rigor.
# If exceeded, build is rejected and a high-cost telemetry event is emitted.
HARD_BUDGET_CAP_USD=25000
#
# Vanguard execution on serverless (e.g. Vercel has no `python` on PATH):
#   auto — try Python, fall back to Node heuristic (default)
#   node — Node only (budget + same keyword/length heuristic as verify-rigor.py)
#   python — Python-only (fails if python missing)
#   off  — bypass ethical scoring only; HARD_BUDGET_CAP_USD still enforced (avoid in prod)
CORPFLOW_VANGUARD_MODE=auto

# -----------------------------
# ROOT — Overseer (async audit)
# -----------------------------
# How many tickets each overseer sweep processes (Approved+Build, most recently updated first).
OVERSEER_SWEEP_LIMIT=10

# Vercel Cron authentication (recommended).
# Vercel supports sending `Authorization: Bearer <CRON_SECRET>` automatically for cron invocations.
# This app accepts either `CRON_SECRET` or `CORPFLOW_CRON_SECRET`.
CRON_SECRET=
CORPFLOW_CRON_SECRET=

# Optional: allow GitHub Actions to callback into CMP and persist PR URLs, etc.
# GitHub repo secrets needed:
# - CMP_AUTOMATION_CALLBACK_URL (example: https://corpflowai.com/api/cmp/automation-callback)
# - CMP_AUTOMATION_CALLBACK_SECRET (must match this value)
CMP_AUTOMATION_CALLBACK_SECRET=

# -----------------------------
# ROOT — MCP servers (optional; used by `mcp_servers.json`)
# -----------------------------
MCP_ENABLED=false
GITHUB_TOKEN=
DATABASE_URL=
BRAVE_API_KEY=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# -----------------------------
# CORE vs TENANT — host boundary (anti-contamination)
# -----------------------------
# **CORE** = factory / ops surface (provision, master console, health). Put this on a dedicated
# hostname, e.g. core.corpflowai.com — listed here so we NEVER derive a client tenant_id from the
# first DNS label (avoids subdomain "core" becoming tenant_id "core").
# Comma-separated hostnames, no protocol; matches Host / X-Forwarded-Host (port stripped).
# Example:
CORPFLOW_CORE_HOSTS=core.corpflowai.com
#
# **Public marketing site** = its own tenant (e.g. tenant_id `corpflowai`).
# Map apex hostname explicitly so it is not confused with the internal default tenant:
# CORPFLOW_TENANT_HOST_MAP={"corpflowai.com":"corpflowai"}
#
# Fallback when apex host is not in the map (legacy / dev only):
CORPFLOW_DEFAULT_TENANT_ID=root
#
# Optional prefix for `{slug}.CORPFLOW_ROOT_DOMAIN` derivation (usually empty).
# CORPFLOW_TENANT_SLUG_PREFIX=
#
# Apex / regional root for subdomain routing (default matches production).
CORPFLOW_ROOT_DOMAIN=corpflowai.com

# -----------------------------
# TENANT — Example mappings
# -----------------------------
# Tenant project IDs (workspace identifiers) — extend as you onboard more clients.
TENANT_LUXE_MAURICE_PROJECT_ID=LX-001
TENANT_LUXE_MAURICE_NOTIFICATION_ID=

