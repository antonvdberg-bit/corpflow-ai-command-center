# CorpFlow AI Command Center — Environment Template
#
# IMPORTANT:
# - This file is a template only. Do NOT commit real secrets.
# - Copy to `.env` locally (or set equivalent variables in your Codespace/CI).
#
# Optional single-blob config in Vercel: CORPFLOW_RUNTIME_CONFIG_JSON must be **strict JSON**
# (double quotes, no trailing commas, no comments). UTF-8 BOM is stripped at runtime.
# Invalid JSON fails closed: critical keys will read as missing until fixed.
#
# ROOT access = general Factory infrastructure.
# TENANT access = per-client workspace IDs / routing identifiers.

# -----------------------------
# ROOT — LLM / AI
# -----------------------------
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-pro

# OpenAI-compatible backend (optional)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (used by `api/index.py`)
GROQ_API_KEY=

# -----------------------------
# ROOT — Baserow / CRM
# -----------------------------
# Primary Baserow endpoint (configurable)
BASEROW_URL=https://crm.corpflowai.com

# API token for Baserow
BASEROW_TOKEN=

# CMP (Change Requests) table ID used by `api/cmp/*` and Baserow row CRUD.
# If your schema uses different column names, override the *_FIELD variables below.
BASEROW_CMP_TABLE_ID=

# Optional fallback for older codepaths
BASEROW_TABLE_ID=

# Baserow REST base URL for database/table provisioning tooling.
BASEROW_BASE_URL=https://api.baserow.io/api/

# Baserow database ID (used by `api/provision.js` and some Baserow tooling).
BASEROW_DB_ID=

# Provisioning endpoint safety:
# `/api/provision` is intentionally disabled by default and will fail-closed unless explicitly enabled.
# When enabled it requires factory master auth and a valid `BASEROW_DB_ID`.
PROVISIONING_ENABLED=false

# Optional: map CMP column names (only if your CRM schema differs).
BASEROW_CMP_DESCRIPTION_FIELD=Description
BASEROW_CMP_STATUS_FIELD=Status
BASEROW_CMP_STAGE_FIELD=Stage
BASEROW_CMP_INITIAL_STATUS=Open
BASEROW_CMP_INITIAL_STAGE=Intake
BASEROW_CMP_BUILD_STAGE_VALUE=Build
BASEROW_CMP_BUILD_STATUS_VALUE=Approved

# Optional per-row overrides
BASEROW_CMP_CLIENT_ID_FIELD=
BASEROW_CMP_SITE_ID_FIELD=

# -----------------------------
# ROOT — Telegram / Alerts
# -----------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------
# ROOT — Dormant Gate (production security)
# -----------------------------
# Enable to hide CMP bubble until an admin SESSION_TOKEN is verified.
DORMANT_GATE_ENABLED=true

# Master secret used to verify SESSION_TOKEN for admin unlocking.
# (In this template we use direct equality; in production prefer a hash.)
MASTER_ADMIN_KEY=

# Optional alias for MASTER_ADMIN_KEY (Vercel Secret). Client sends the same value as x-session-token.
ADMIN_PIN=

# Session token expected from admin; verify logic compares this to MASTER_ADMIN_KEY.
# Typically set by an admin bootstrap flow and stored client-side.
SESSION_TOKEN=

# WhatsApp number(s) for exec escalation (optional).
EXEC_WHATSAPP_NUMBER=

# -----------------------------
# ROOT — Vercel
# -----------------------------
# GitHub App / deployment signing PEM (required on Vercel for vanguard/notary.js APP signatures).
APP_PRIVATE_KEY=

VERCEL_AUTH_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# -----------------------------
# ROOT — Twilio / WhatsApp (optional)
# -----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ADMIN_WHATSAPP_NUMBER=
WHATSAPP_FROM=whatsapp:+14155238886

# -----------------------------
# ROOT — Sandbox / Code Execution (optional)
# -----------------------------
SANDBOX_TYPE=local
SANDBOX_TIMEOUT_SEC=30
SANDBOX_MAX_OUTPUT_KB=64

MSB_SERVER_URL=http://127.0.0.1:5555
MSB_API_KEY=
MSB_IMAGE=microsandbox/python
MSB_CPU_LIMIT=1.0
MSB_MEMORY_MB=512
MSB_START_TIMEOUT_SEC=30

# -----------------------------
# ROOT — External glue tooling (optional)
# -----------------------------
# Used by `sync_conductor.py` to poll a Google Apps Script endpoint.
GOOGLE_SCRIPT_URL=

# -----------------------------
# ROOT — Ethical Sentinel / Budget Gate
# -----------------------------
# Hard cap for cost_estimate/full_market_value_usd used by verify-rigor.
# If exceeded, build is rejected and a high-cost telemetry event is emitted.
HARD_BUDGET_CAP_USD=25000

# -----------------------------
# ROOT — MCP servers (optional; used by `mcp_servers.json`)
# -----------------------------
MCP_ENABLED=false
GITHUB_TOKEN=
DATABASE_URL=
BRAVE_API_KEY=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# -----------------------------
# CORE vs TENANT — host boundary (anti-contamination)
# -----------------------------
# **CORE** = factory / ops surface (provision, master console, health). Put this on a dedicated
# hostname, e.g. core.corpflowai.com — listed here so we NEVER derive a client tenant_id from the
# first DNS label (avoids subdomain "core" becoming tenant_id "core").
# Comma-separated hostnames, no protocol; matches Host / X-Forwarded-Host (port stripped).
# Example:
CORPFLOW_CORE_HOSTS=core.corpflowai.com
#
# **Public marketing site** = its own Baserow-backed tenant (e.g. tenant_id `corpflowai`).
# Map apex hostname explicitly so it is not confused with the internal default tenant:
# CORPFLOW_TENANT_HOST_MAP={"corpflowai.com":"corpflowai"}
#
# Fallback when apex host is not in the map (legacy / dev only):
CORPFLOW_DEFAULT_TENANT_ID=root
#
# Optional prefix for `{slug}.CORPFLOW_ROOT_DOMAIN` derivation (usually empty).
# CORPFLOW_TENANT_SLUG_PREFIX=
#
# Apex / regional root for subdomain routing (default matches production).
CORPFLOW_ROOT_DOMAIN=corpflowai.com

# -----------------------------
# TENANT — Example mappings
# -----------------------------
# Tenant project IDs (workspace identifiers) — extend as you onboard more clients.
TENANT_LUXE_MAURICE_PROJECT_ID=LX-001
TENANT_LUXE_MAURICE_BASEROW_TABLE_ID=
TENANT_LUXE_MAURICE_NOTIFICATION_ID=

