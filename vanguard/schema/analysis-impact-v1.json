{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corpflowai.com/vanguard/schema/analysis-impact-v1.json",
  "title": "AnalysisImpactV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ticket_id", "summary", "risk_level", "technical_risks"],
  "properties": {
    "schema_version": { "const": "1" },
    "ticket_id": { "type": "string" },
    "summary": { "type": "string", "description": "Executive impact summary." },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "technical_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["area", "severity", "mitigation"],
        "properties": {
          "area": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "affected_surfaces": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g. api, public tier, webhook"
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
