{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corpflowai.com/vanguard/schema/dam-v1.json",
  "schema_version": "1",
  "title": "Delegated Authority Matrix (DAM) v1",
  "description": "Defines high-risk actions and the tenant tiers permitted to execute them.",
  "high_risk_actions": [
    {
      "action_key": "refunds",
      "match_any": {
        "tool_name_keywords": ["refund", "refunds", "chargeback"]
      },
      "allowed_tiers": ["EVOLVING"],
      "default_denied": true
    },
    {
      "action_key": "schema_changes",
      "match_any": {
        "tool_name_keywords": [
          "schema",
          "migration",
          "migrate",
          "prisma",
          "add_column",
          "alter_table"
        ]
      },
      "allowed_tiers": ["EVOLVING"],
      "default_denied": true
    },
    {
      "action_key": "bulk_data_export",
      "match_any": {
        "tool_name_keywords": ["bulk", "export", "download", "csv", "export_data"]
      },
      "allowed_tiers": ["EVOLVING"],
      "default_denied": true
    }
  ]
}

