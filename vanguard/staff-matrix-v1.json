{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corpflowai.com/vanguard/schema/staff-matrix-v1.json",
  "title": "StaffMatrixV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tenant_id", "functional_clusters", "authorized_representatives", "staff_members"],
  "properties": {
    "schema_version": { "const": "1" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "functional_clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["Marketing", "Operations", "Financials", "Tech_Admin"]
      },
      "description": "Functional clusters supported by the tenant."
    },
    "authorized_representatives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["staff_id", "display_name", "contact_details"],
        "properties": {
          "staff_id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "contact_details": {
            "type": "object",
            "additionalProperties": false,
            "required": ["whatsapp_number"],
            "properties": {
              "whatsapp_number": { "type": "string", "minLength": 1, "description": "E.164 or whatsapp:+<e164>." },
              "email": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "staff_members": {
      "type": "object",
      "additionalProperties": false,
      "description": "Map staff_id -> cluster memberships.",
      "patternProperties": {
        "^[a-zA-Z0-9_\\-]+$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["display_name", "clusters_enabled"],
          "properties": {
            "display_name": { "type": "string", "minLength": 1 },
            "clusters_enabled": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["Marketing", "Operations", "Financials", "Tech_Admin"]
              }
            },
            "contact_details": {
              "type": "object",
              "additionalProperties": false,
              "required": ["whatsapp_number"],
              "properties": {
                "whatsapp_number": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}

