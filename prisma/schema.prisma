generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}
model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  intent    String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}
