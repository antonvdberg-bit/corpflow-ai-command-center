generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  revenueRange  String?
  manualHours   Int?
  gapScore      Float?
  createdAt     DateTime @default(now())
}

model CaseLaw {
  id          String   @id @default(cuid())
  caseNumber  String   @unique // e.g., 2026 SCJ 142
  parties     String   // e.g., "MRA vs GlobalFin Ltd"
  summary     String   @db.Text
  rulingDate  DateTime
  tags        String[] // "Tax", "Labor", "Fintech"
  createdAt   DateTime @default(now())
}
