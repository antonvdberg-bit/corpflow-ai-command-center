generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Lead {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  revenueRange  String?
  manualHours   Int?
  gapScore      Float?
  createdAt     DateTime @default(now())
}
