# Minimal example — copy to `.env` and fill in. See `.env.template` for full list.
POSTGRES_URL=
CORPFLOW_AUTH_BACKEND=postgres
CORPFLOW_TENANTS_BACKEND=postgres

# Optional: Change Console “Site preview” via Vercel API (promote-status / refresh promotion)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# Optional: GitHub Actions → factory callback (PR metadata + preview_url)
# CMP_AUTOMATION_CALLBACK_SECRET=
# CMP_AUTOMATION_CALLBACK_URL=https://your-deployment/api/cmp/automation-callback
