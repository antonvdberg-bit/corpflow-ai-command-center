# Minimal example — copy to `.env` and fill in. See `.env.template` for full list.
#
# Repo-root `.env` and `.env.local` are loaded automatically when you run Node scripts from
# `scripts/` (e.g. npm run control:loop, npm run ci:report, npm run vercel:env:check).
# You do not need to re-export variables in every new terminal unless you prefer shell-only secrets.
#
# Precedence: values already in the shell win; then `.env.local`; then `.env`.
# `VERCEL_AUTH_TOKEN` is treated as `VERCEL_TOKEN` when the latter is unset.
# `CORPFLOW_PUBLIC_BASE_URL` fills `FACTORY_HEALTH_URL` for control:loop when health URL is unset.

POSTGRES_URL=
CORPFLOW_AUTH_BACKEND=postgres
CORPFLOW_TENANTS_BACKEND=postgres

# Optional: Change Console “Site preview” via Vercel API (promote-status / refresh promotion)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# Optional: npm run control:loop — same as setting FACTORY_HEALTH_URL if you already use public base:
# CORPFLOW_PUBLIC_BASE_URL=https://your-production-host
# FACTORY_HEALTH_URL=https://your-production-host
# VERCEL_DEPLOY_HOOK_URL=

# Optional: GitHub Actions → factory callback (PR metadata + preview_url)
# CMP_AUTOMATION_CALLBACK_SECRET=
# CMP_AUTOMATION_CALLBACK_URL=https://your-deployment/api/cmp/automation-callback
