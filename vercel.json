{
  "version": 2,
  "build": {
    "env": {
      "UV_LINK_MODE": "copy"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/factory_router?__path=$1" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/change", "destination": "/change.html" },
    { "source": "/growth", "destination": "/growth.html" },
    { "source": "/sovereign-intake", "destination": "/sovereign-intake.html" },
    { "source": "/legal", "destination": "/public/legal-demo.html" },
    { "source": "/medical", "destination": "/public/proposal-medspa.html" },
    { "source": "/lux", "destination": "/showcase/luxe-maurice-private/index.html" },
    { "source": "/lux-editor", "destination": "/lux-site-editor.html" },
    { "source": "/lux-guide", "destination": "/lux-client-guide.html" },
    { "source": "/master", "destination": "/public/master-control.html" },
    { "source": "/factory/auth-users", "destination": "/factory-auth-users.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/billing-sentinel",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cmp/overseer-sweep-cron",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cmp/stuck-self-repair-cron",
      "schedule": "*/20 * * * *"
    }
  ]
}
