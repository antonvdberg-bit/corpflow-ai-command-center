{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/factory_router?__path=$1" },
    { "source": "/change", "destination": "/change.html" },
    { "source": "/legal", "destination": "/public/legal-demo.html" },
    { "source": "/medical", "destination": "/public/proposal-medspa.html" },
    { "source": "/lux", "destination": "/showcase/luxe-maurice-private/index.html" },
    { "source": "/master", "destination": "/public/master-control.html" }
  ],
  "env": {
    "BASEROW_URL": "REPLACE_ME_BASEROW_URL",
    "BASEROW_CMP_TABLE_ID": "REPLACE_ME_BASEROW_CMP_TABLE_ID"
  },
  "build": {
    "env": {
      "BASEROW_URL": "REPLACE_ME_BASEROW_URL",
      "BASEROW_CMP_TABLE_ID": "REPLACE_ME_BASEROW_CMP_TABLE_ID"
    }
  },
  "crons": [
    {
      "path": "/api/cron/billing-sentinel",
      "schedule": "0 0 * * *"
    }
  ]
}
