{
  "version": 2,
  "name": "corpflow-ai-command-center",
  "builds": [
    { "src": "public/*.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "env": {
    "PERFORMANCE_FLOOR": "85"
  }
}
